generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Organizacion {
  id           String   @id @default(cuid())
  nombre       String
  tipo         String?  // "Hospital", "Empresa", "Clínica", etc.
  createdAt    DateTime @default(now())

  usuarios     UsuarioOrganizacion[]
  funcionarios Funcionario[]
  equipos      Equipo[]
  insumos      Insumo[]
  historialEquipos   HistorialEquipo[]
  movimientosInsumos MovimientoInsumo[]
}

model Usuario {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String   // hasheado con bcrypt
  createdAt DateTime @default(now())

  organizaciones UsuarioOrganizacion[]
  historialEquipos   HistorialEquipo[]
  movimientosInsumos MovimientoInsumo[]
}

model UsuarioOrganizacion {
  usuarioId      String
  organizacionId String
  rol            String @default("ADMIN")

  usuario      Usuario      @relation(fields: [usuarioId], references: [id])
  organizacion Organizacion @relation(fields: [organizacionId], references: [id])

  @@id([usuarioId, organizacionId])
}

model Funcionario {
  id             String   @id @default(cuid())
  nombre         String
  rut            String?
  cargo          String?
  departamento   String?
  telefono       String?
  email          String?
  createdAt      DateTime @default(now())

  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])
  equipos        Equipo[]
  historialEquipos HistorialEquipo[]

  @@index([organizacionId])
}

model Equipo {
  id             String   @id @default(cuid())
  tipo           String   // "PC", "Notebook", "Impresora"
  marca          String?
  modelo         String?
  serial         String?
  ip             String?
  mac            String?
  ram            String?
  estado         String   @default("ACTIVO") // "ACTIVO", "BODEGA", "BAJA"
  notas          String?
  createdAt      DateTime @default(now())

  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])

  funcionarioId  String?
  funcionario    Funcionario? @relation(fields: [funcionarioId], references: [id])
  historial      HistorialEquipo[]

  @@index([organizacionId])
  @@index([funcionarioId])
}

model Insumo {
  id             String   @id @default(cuid())
  nombre         String   // Ej: "Tóner HP 85A"
  tipo           String?  // "Tóner", "Tinta"
  modelo         String?  // Compatible con qué impresora
  stockActual    Int      @default(0)
  stockMinimo    Int      @default(2) // Alerta si baja de este número
  createdAt      DateTime @default(now())

  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])
  movimientos    MovimientoInsumo[]

  @@index([organizacionId])
}

model HistorialEquipo {
  id             String       @id @default(cuid())
  equipoId       String
  equipo         Equipo       @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  funcionarioId  String?
  funcionario    Funcionario? @relation(fields: [funcionarioId], references: [id], onDelete: SetNull)
  usuarioId      String       // Usuario que realiza el cambio/asignación
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  estado         String       // "ACTIVO", "BODEGA", "BAJA"
  tipoMovimiento String       // "ASIGNACION", "DEVOLUCION", "CREACION", "BAJA", "MODIFICACION"
  notas          String?      // Razón del cambio
  createdAt      DateTime     @default(now())
  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)

  @@index([equipoId])
  @@index([funcionarioId])
  @@index([usuarioId])
  @@index([organizacionId])
}

model MovimientoInsumo {
  id             String       @id @default(cuid())
  insumoId       String
  insumo         Insumo       @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  usuarioId      String       // Usuario que registra el movimiento
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  cantidad       Int          // Ejemplo: +5 (entrada) o -2 (salida)
  tipo           String       // "ENTRADA", "SALIDA"
  motivo         String?      // Ej: "Box 3 - Urgencias", "Compra anual de Tóner"
  createdAt      DateTime     @default(now())
  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)

  @@index([insumoId])
  @@index([usuarioId])
  @@index([organizacionId])
}
